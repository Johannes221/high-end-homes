// Prisma Schema für High-End Homes

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model QuoteRequest {
  id                String   @id @default(cuid())
  type              String
  name              String
  email             String
  phone             String?
  company           String?
  address           String?
  squareMeters      Int
  buildingType      String   @default("")
  constructionYear  String?
  floor             String?
  elevator          String?
  materialsJson     String
  removalItemsJson  String
  quantityEstimate  String?
  valuables         String?
  asbestosRequired  Boolean  @default(false)
  otherPollutants   Boolean  @default(false)
  disposalWanted    Boolean  @default(false)
  permitStatus      String?
  desiredDate       String?
  imageFileNamesJson String
  imagesBase64Json  String   @default("[]")
  notes             String?
  complexityScore   Int
  complexityLevel   String
  effortRange       String
  complexityFlagsJson String
  estimatedMinPrice Int
  estimatedMaxPrice Int
  approvalStatus    String   @default("pending")
  approvedAt        DateTime?
  approvedBy        String?
  sharedAt          DateTime?
  payloadJson       String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
